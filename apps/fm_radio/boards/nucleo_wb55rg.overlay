&i2c1 {
    pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
    pinctrl-names = "default";
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;

    rda5807m: fm_radio@10 {
        compatible = "rda,rda5807m";
        reg = <0x10>;
        vol-default = <8>;
        band = "87-108";
        status = "okay";
    };
};