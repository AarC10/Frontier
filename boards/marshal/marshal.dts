/dts-v1/;

#include <st/g4/stm32g474Xe.dtsi>
#include <st/g4/stm32g474c(b-c-e)tx-pinctrl.dtsi>
#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/pwm/pwm.h>
#include <zephyr/dt-bindings/sensor/lsm6dsv16x.h>

/ {
	model = "Marshal Flight Computer";
	compatible = "wildwest,marshal";

	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;

		zephyr,settings-partition = &nvs_partition;
	};

	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpioa 15 GPIO_ACTIVE_HIGH>;
			label = "Status LED";
		};

		buzzer: buzzer {
			gpios = <&gpiob 2 GPIO_ACTIVE_HIGH>;
			label = "Buzzer Enable";
		};
	};

	pyro: pyro {
		stm_ch1_en: stm_ch1_en {
			gpios = <&gpiob 9 GPIO_ACTIVE_HIGH>;
			label = "STM-CH1-EN";
		};

		stm_ch2_en: stm_ch2_en {
			gpios = <&gpiob 7 GPIO_ACTIVE_HIGH>;
			label = "STM-CH2-EN";
		};

		flt1: flt1 {
			gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
			label = "FLT1";
		};

		flt2: flt2 {
			gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;
			label = "FLT2";
		};
	};

	buzzer_pwm: buzzer_pwm {
		pwms = <&pwm4 4 PWM_HZ(2000) PWM_POLARITY_NORMAL>;
	};

	flashdisk0: flashdisk0 {
		compatible = "zephyr,flash-disk";
		partition = <&fat_partition>;
		disk-name = "marshal";
		cache-size = <4096>;
		status = "okay";
	};

	fstab {
		compatible = "zephyr,fstab";

		fatfs0: fatfs0 {
			compatible = "zephyr,fstab,fatfs";
			disk-access;
			mount-point = "/export";
		};
	};

	vbat_sensor: vbat_sensor {
		compatible = "voltage-divider";
		io-channels = <&adc1 1>;
		output-ohms = <22000>;
		full-ohms = <222000>;
	};

	vcc_sensor: vcc_sensor {
		compatible = "voltage-divider";
		io-channels = <&adc1 2>;
		output-ohms = <68000>;
		full-ohms = <168000>;
	};

	aliases {
		led = &led0;
		buzzer = &buzzer;
		barometer = &ms5611;
		imu = &lsm6dsv16x;
		dbg-uart = &usart2;
		stm-ch1-en = &stm_ch1_en;
		stm-ch2-en = &stm_ch2_en;
		flt1 = &flt1;
		flt2 = &flt2;
		pyro1-ilm = &pyro1_ilm;
		pyro2-ilm = &pyro2_ilm;
		vbat-sense = &vbat_sense;
		v3v3-sense = &v3v3_sense;
		buzzer-pwm = &buzzer_pwm;
		vbat-sensor = &vbat_sensor;
		vcc-sensor = &vcc_sensor;
		fat-disk = &flashdisk0;
		fatfs0 = &fatfs0;
	};
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(16)>;
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

//&crs {
//    clocks = <&clk_hsi48>;
//    clock-frequency = <DT_FREQ_M(48)>;
//    sync-src = <STM32_CRS_SYNC_SRC_USB>;
//    status = "okay";
//};

//&clk_hsi {
//    clock-frequency = <DT_FREQ_M(16)>;
//    status = "okay";
//};

&pll {
    div-m = <2>;
    mul-n = <20>;
    div-p = <2>;
    div-q = <2>;
    div-r = <2>;
    clocks = <&clk_hse>;
    status = "okay";
};

&rcc {
    clocks = <&pll>;
    clock-frequency = <DT_FREQ_M(80)>;
    ahb-prescaler = <1>;
    apb1-prescaler = <1>;
    apb2-prescaler = <1>;
};

&ucpd1 {
	psc-ucpdclk = <1>;
	hbitclkdiv = <27>;
	pinctrl-0 = <&ucpd1_cc1_pb6 &ucpd1_cc2_pb4>;
	pinctrl-names = "default";
	status = "disabled";
};


&spi1 {
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	cs-gpios = <&gpiob 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>,
		   <&gpiob 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	status = "okay";

	ms5611: ms5611@0 {
		compatible = "te,ms5611";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(10)>;
		status = "okay";
	};

	lsm6dsv16x: lsm6dsv16x@1 {
		compatible = "st,lsm6dsv16x";
		reg = <1>;
		spi-max-frequency = <DT_FREQ_M(10)>;

		accel-odr = <LSM6DSVXXX_DT_ODR_AT_240Hz>;
    	gyro-odr = <LSM6DSVXXX_DT_ODR_AT_240Hz>;

		drdy-pin = <1>;
		drdy-pulsed;

		int1-gpios = <&gpioc 14 GPIO_ACTIVE_HIGH>;
		int2-gpios = <&gpioc 15 GPIO_ACTIVE_HIGH>;

		status = "okay";
	};
};

&spi2 {
	pinctrl-0 = <&spi2_sck_pb13 &spi2_miso_pb14 &spi2_mosi_pb15>;
	pinctrl-names = "default";
	cs-gpios = <&gpiob 12 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	status = "okay";

	w25q128jvsiq: spi-nor-flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(104)>;
		size = <DT_SIZE_M(128)>;
        jedec-id = [ef 40 18];

		wp-gpios = <&gpioa 10 GPIO_ACTIVE_LOW>;
		reset-gpios = <&gpiob 10 GPIO_ACTIVE_LOW>;
		status = "okay";

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			// 16 KB for configs
			nvs_partition: partition@0 {
				label = "nvs_storage";
				reg = <0x00000000 0x4000>;
			};

			// 12 MB for flight critical logging
			raw_partition: partition@4000 {
				label = "raw_log";
				reg = <0x00004000 0xBFC000>;
			};

			// 4 MB for exporting over FAT
			fat_partition: partition@C00000 {
				label = "fat_export";
				reg = <0x00C00000 0x400000>;
			};
		};
	};
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&timers4 {
	status = "okay";

	pwm4: pwm {
		status = "okay";
		pinctrl-0 = <&tim4_ch4_pb9>;
		pinctrl-names = "default";
	};
};

&adc1 {
	pinctrl-0 = <&adc1_in1_pa0 &adc1_in2_pa1>;
	pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <4>;
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	vbat_sense: channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
		zephyr,vref-mv = <3300>;
	};

	v3v3_sense: channel@2 {
		reg = <2>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
		zephyr,vref-mv = <3300>;
	};
};

&adc5 {
	pinctrl-0 = <&adc5_in1_pa8 &adc5_in2_pa9>;
	pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <4>;
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	pyro1_ilm: channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
		zephyr,vref-mv = <3300>;
	};

	pyro2_ilm: channel@2 {
		reg = <2>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
		zephyr,vref-mv = <3300>;
	};
};

zephyr_udc0: &usb {
	pinctrl-0 = <&usb_dm_pa11 &usb_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";

	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};
