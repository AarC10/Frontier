# Serial Drivers
CONFIG_SERIAL=y
#CONFIG_UART_INTERRUPT_DRIVEN=y
# enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# USB
CONFIG_USB_DEVICE_STACK_NEXT=y

# GPIO Controller
CONFIG_GPIO=y
CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=170000000

# Sensors
CONFIG_SENSOR=y
CONFIG_MS56XX=y