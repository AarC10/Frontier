# Serial
CONFIG_SERIAL=y
CONFIG_UART_INTERRUPT_DRIVEN=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# USB hardware
CONFIG_USB_DEVICE_STACK_NEXT=y
CONFIG_USBC_STACK=n

# GPIO
CONFIG_GPIO=y

# Clock
CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=80000000

# Sensors
CONFIG_SENSOR=y
CONFIG_MS56XX=y
CONFIG_LSM6DSV16X_TRIGGER_OWN_THREAD=y